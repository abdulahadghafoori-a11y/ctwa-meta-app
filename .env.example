# Copy to .env.local and fill in values (see README.md).

# Neon Postgres — pooled connection string is fine for serverless
DATABASE_URL=

META_ACCESS_TOKEN=
META_PIXEL_ID=

# Optional — Meta Events Manager → Test Events
# META_TEST_EVENT_CODE=

# YCloud → POST /api/webhooks/ycloud (HMAC verify; optional in dev, required in prod)
# Get signing secret when creating the endpoint in YCloud Console → Developers → Webhooks
# YCLOUD_WEBHOOK_SECRET=
